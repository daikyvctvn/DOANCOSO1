@{
    ViewData["Title"] = "Tổng quan";

    var gallerySlides = new[]
    {
        new { ImageUrl = "/images/gallery/anh-1.jpg", Title = "Anh ca nhan 01" },
        new { ImageUrl = "/images/gallery/anh-2.jpg", Title = "Anh ca nhan 02" },
        new { ImageUrl = "/images/gallery/anh-3.jpg", Title = "Anh ca nhan 03" },
        new { ImageUrl = "/images/gallery/anh-4.jpg", Title = "Anh ca nhan 04" },
        new { ImageUrl = "/images/gallery/anh-5.jpg", Title = "Anh ca nhan 05" },
        new { ImageUrl = "/images/gallery/anh-6.jpg", Title = "Anh ca nhan 06" }
    };
}

<section class="section-block">
    <div id="overviewGallery" class="carousel slide gallery-carousel" data-bs-ride="carousel" data-bs-interval="4500">
        <div class="carousel-indicators gallery-carousel__indicators">
            @for (var i = 0; i < gallerySlides.Length; i++)
            {
                <button type="button"
                        data-bs-target="#overviewGallery"
                        data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"
                        aria-current="@(i == 0 ? "true" : null)"
                        aria-label="Anh @(i + 1)"></button>
            }
        </div>
        <div class="carousel-inner">
            @for (var i = 0; i < gallerySlides.Length; i++)
            {
                var slide = gallerySlides[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <div class="gallery-slide">
                        <img src="@slide.ImageUrl" alt="@slide.Title" onerror="this.onerror=null;this.src='/images/gallery/placeholder.svg';" />
                        <div class="gallery-slide__copy">
                            <span>0@(i + 1)</span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev gallery-carousel__control gallery-carousel__control--prev" type="button" data-bs-target="#overviewGallery" data-bs-slide="prev">
            <span aria-hidden="true">&lsaquo;</span>
            <span class="visually-hidden">Anh truoc</span>
        </button>
        <button class="carousel-control-next gallery-carousel__control gallery-carousel__control--next" type="button" data-bs-target="#overviewGallery" data-bs-slide="next">
            <span aria-hidden="true">&rsaquo;</span>
            <span class="visually-hidden">Anh tiep theo</span>
        </button>
        <button class="gallery-carousel__hitbox gallery-carousel__hitbox--prev" type="button" data-bs-target="#overviewGallery" data-bs-slide="prev">
            <span class="visually-hidden">Anh truoc</span>
        </button>
        <button class="gallery-carousel__hitbox gallery-carousel__hitbox--next" type="button" data-bs-target="#overviewGallery" data-bs-slide="next">
            <span class="visually-hidden">Anh tiep theo</span>
        </button>
    </div>
</section>

<section class="spice-footer-logo" aria-label="Spice Temple Thai Inspired">
    <div class="spice-footer-logo__mark">
        <div class="spice-footer-logo__name">
            <span>SPICE</span>
            <span>TEMPLE</span>
        </div>
        <div class="spice-footer-logo__tagline">THAI INSPIRED</div>
    </div>
    <div class="spice-footer-logo__hours">
        <span>MONDAY - SUNDAY</span>
        <strong>10:30 AM - 10:00 PM</strong>
    </div>
</section>
