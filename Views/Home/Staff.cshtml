@model TableOrderWeb.Models.StaffPageViewModel
@{
    ViewData["Title"] = "Nhân viên";

    var posCards = new[]
    {
        new { Label = "Đơn mới", Value = Model.NewOrderCount.ToString("00"), Note = "Nhận đơn và chuyển bếp/bar" },
        new { Label = "Tin chat chờ", Value = Model.PendingChatCount.ToString("00"), Note = "Khách đang cần phản hồi" },
        new { Label = "Thanh toán chờ", Value = Model.PendingPaymentCount.ToString("00"), Note = "Khách đã bấm thanh toán" },
        new { Label = "Bàn đang mở", Value = Model.ActiveTableCount.ToString("00"), Note = "Có đơn, chat hoặc bill" }
    };

    var quickOrderStatuses = new[]
    {
        new { Value = "accepted", Label = "Nhận đơn", ClassName = "staff-action-button--accept" },
        new { Value = "preparing", Label = "Đang làm", ClassName = "staff-action-button--cook" },
        new { Value = "ready", Label = "Xong món", ClassName = "staff-action-button--ready" },
        new { Value = "served", Label = "Đã phục vụ", ClassName = "staff-action-button--served" }
    };

    var tableStates = new[] { "Bàn trống", "Đang ngồi", "Đang phục vụ", "Chờ dọn dẹp", "Đã thanh toán" };
}

<div class="staff-page" data-auto-refresh-url="@Url.Action("Staff")" data-auto-refresh-seconds="20">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-alert success admin-alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="auth-alert admin-alert">@Model.ErrorMessage</div>
    }

    <section class="staff-metrics">
        @foreach (var card in posCards)
        {
            <article class="metric-card staff-metric-card">
                <span>@card.Label</span>
                <strong>@card.Value</strong>
                <p>@card.Note</p>
            </article>
        }
    </section>

    <section class="staff-workspace">
        <div class="staff-workspace__main">
            <article class="panel-card staff-section" id="orders">
                <div class="panel-heading staff-section__head">
                    <div>
                        <h2>Đơn khách vừa gửi</h2>
                    </div>
                    <span class="status-badge">@Model.Orders.Count đơn</span>
                </div>

                <div class="staff-order-list">
                    @if (Model.Orders.Count == 0)
                    {
                        <div class="staff-empty-state">
                            <strong>Chưa có đơn mới</strong>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in Model.Orders)
                        {
                            <article class="staff-order-card">
                                <div class="staff-order-card__top">
                                    <div>
                                        <span class="staff-table-pill">Bàn @order.TableCode</span>
                                        <strong>#@order.OrderCode</strong>
                                    </div>
                                    <span class="status-badge">@order.StatusLabel</span>
                                </div>
                                <p>@order.ItemsSummary</p>
                                <small>@order.SubmittedTimeLabel | @order.PaymentLabel</small>
                                <small>Ghi chú: @order.NotesSummary</small>

                                <div class="staff-order-card__actions">
                                    @foreach (var status in quickOrderStatuses)
                                    {
                                        <form asp-action="UpdateOrderStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="OrderId" value="@order.OrderId" />
                                            <input type="hidden" name="Status" value="@status.Value" />
                                            <button class="staff-action-button @status.ClassName" type="submit">@status.Label</button>
                                        </form>
                                    }
                                    <span class="staff-money">@order.TotalAmount.ToString("N0")đ</span>
                                </div>
                            </article>
                        }
                    }
                </div>
            </article>

            <article class="panel-card staff-section" id="kitchen">
                <div class="panel-heading staff-section__head">
                    <div>
                        <h2>Món cần làm</h2>
                    </div>
                    <span class="status-badge">@Model.KitchenItemCount món</span>
                </div>

                <div class="staff-kitchen-list">
                    @if (Model.KitchenItems.Count == 0)
                    {
                        <div class="staff-empty-state">
                            <strong>Không có món trong hàng đợi</strong>
                        </div>
                    }
                    else
                    {
                        @foreach (var ticket in Model.KitchenItems.GroupBy(item => new
                        {
                            item.OrderId,
                            item.OrderCode,
                            item.TableCode,
                            item.StatusLabel,
                            item.SubmittedTimeLabel
                        }))
                        {
                            <article class="staff-kitchen-ticket">
                                <div class="staff-kitchen-ticket__head">
                                    <div>
                                        <strong>Bàn @ticket.Key.TableCode</strong>
                                        <span>Đơn #@ticket.Key.OrderCode</span>
                                    </div>
                                    <div>
                                        <b>@ticket.Key.SubmittedTimeLabel</b>
                                        <span>@ticket.Key.StatusLabel</span>
                                    </div>
                                </div>

                                <div class="staff-kitchen-ticket__items">
                                    @foreach (var item in ticket)
                                    {
                                        <div class="staff-kitchen-line">
                                            <div>
                                                <strong>@item.ItemName</strong>
                                                <span>@item.Note</span>
                                            </div>
                                            <b>x@(item.Quantity)</b>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    }
                </div>
            </article>

            <article class="panel-card staff-section">
                <div class="panel-heading staff-section__head">
                    <div>
                        <h2>Hội thoại theo bàn</h2>
                    </div>
                    <span class="status-badge">@Model.ChatThreads.Sum(x => x.PendingCount) tin chờ</span>
                </div>

                <div class="staff-chat-list">
                    @if (Model.ChatThreads.Count == 0)
                    {
                        <div class="staff-empty-state">
                            <strong>Chưa có tin nhắn</strong>
                        </div>
                    }
                    else
                    {
                        @foreach (var thread in Model.ChatThreads)
                        {
                            <details class="staff-chat-card staff-chat-card--collapsible" open="@(thread.PendingCount > 0 ? "open" : null)">
                                <summary class="staff-chat-summary">
                                    <strong>Bàn @thread.TableCode</strong>
                                    @if (thread.PendingCount > 0)
                                    {
                                        <span class="status-badge staff-unread-badge">Có tin nhắn chưa đọc</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge muted">Đã đọc</span>
                                    }
                                    <small>@thread.LastMessageLabel</small>
                                    <form class="staff-chat-delete-form" asp-action="DeleteTableChat" method="post" onclick="event.stopPropagation()">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="tableCode" value="@thread.TableCode" />
                                        <button class="btn btn-ghost btn-small" type="submit" onclick="return confirm('Xóa hội thoại bàn @thread.TableCode?')">Xóa</button>
                                    </form>
                                </summary>

                                <div class="staff-chat-card__body">
                                    <div class="chat-thread compact-stack">
                                        @foreach (var message in thread.Messages)
                                        {
                                            var side = string.Equals(message.SenderRole, "Staff", StringComparison.OrdinalIgnoreCase) ? "mine" : "theirs";
                                            <div class="chat-bubble chat-bubble--@message.Direction chat-message chat-message--@side">
                                                @if (side == "theirs")
                                                {
                                                    <strong class="chat-message__name">@message.SenderName</strong>
                                                }
                                                <p>@message.Message</p>
                                                <small class="chat-message__time">@message.TimeLabel</small>
                                            </div>
                                        }
                                    </div>

                                    <form class="staff-reply-form" asp-action="SendStaffMessage" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TableCode" value="@thread.TableCode" />
                                        <input name="Message" placeholder="Nhập phản hồi nhanh..." />
                                        <button class="btn btn-accent btn-small" type="submit">Gửi</button>
                                    </form>
                                </div>
                            </details>
                        }
                    }
                </div>
            </article>
        </div>

        <aside class="staff-workspace__side">
            <article class="panel-card staff-section" id="payments">
                <div class="panel-heading staff-section__head">
                    <div>
                        <h3>Yêu cầu từ khách</h3>
                    </div>
                    <span class="status-badge">@Model.PaymentRequests.Count yêu cầu</span>
                </div>

                <div class="staff-payment-list">
                    @if (Model.PaymentRequests.Count == 0)
                    {
                        <div class="staff-empty-state">
                            <strong>Chưa có yêu cầu thanh toán</strong>
                        </div>
                    }
                    else
                    {
                        @foreach (var payment in Model.PaymentRequests)
                        {
                            <article class="staff-payment-card">
                                <strong>Bàn @payment.TableCode</strong>
                                <span>@payment.MethodLabel</span>
                                <span>@payment.RequestedAtLabel | @payment.StatusLabel</span>
                                <b>@payment.Amount.ToString("N0")đ</b>
                                @if (!string.IsNullOrWhiteSpace(payment.Note))
                                {
                                    <p>@payment.Note</p>
                                }
                            </article>
                        }
                    }
                </div>
            </article>

            <article class="panel-card staff-section" id="tables">
                <div class="panel-heading staff-section__head">
                    <div>
                        <h3>Cập nhật nhanh</h3>
                    </div>
                </div>

                <div class="staff-table-list">
                    @foreach (var table in Model.TableStatuses)
                    {
                        <article class="staff-table-card">
                            <div>
                                <strong>Bàn @table.TableCode</strong>
                                <span>@table.State</span>
                                <small>Bill mở: @table.OutstandingTotal.ToString("N0")đ | @table.LastActivityLabel</small>
                            </div>
                            <form asp-action="UpdateTableState" method="post" class="staff-table-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="TableCode" value="@table.TableCode" />
                                <select name="State">
                                    @foreach (var state in tableStates)
                                    {
                                        <option value="@state">@state</option>
                                    }
                                </select>
                                <button class="btn btn-ghost btn-small" type="submit">Lưu</button>
                            </form>
                        </article>
                    }
                </div>
            </article>
        </aside>
    </section>
</div>
