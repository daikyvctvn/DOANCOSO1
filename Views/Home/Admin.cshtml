@model TableOrderWeb.Models.AdminMenuPageViewModel
@{
    ViewData["Title"] = "Quan tri";

    var topMetrics = new[]
    {
        new { Label = "Tong so mon", Value = Model.MenuItems.Count.ToString(), Note = "Tat ca mon hien co trong SQL" },
        new { Label = "Mon dang ban", Value = Model.MenuItems.Count(x => x.IsAvailable).ToString(), Note = "Khach dang co the dat tu menu web" },
        new { Label = "Best seller", Value = Model.MenuItems.Count(x => x.IsBestSeller).ToString(), Note = "Mon dang duoc danh dau noi bat" }
    };

    var imageSuggestions = new[]
    {
        new { Label = "Quyen Admin", Copy = "Chi tai khoan role Admin moi duoc them, sua va xoa mon." },
        new { Label = "Quyen Staff", Copy = "Staff chi vao duoc man hinh nhan vien, khong duoc goi API CRUD menu." },
        new { Label = "Khach hang", Copy = "Khach tai ban chi xem menu va dat mon, khong co quyen can thiep du lieu." }
    };

    var tables = new[] { "A01", "A02", "A03", "A04", "A05", "A06", "A07", "A08", "B01", "B02", "B03", "B04", "B05", "B06", "C01", "C02", "C03", "C04" };
}

<section class="page-intro">
    <div>
        <span class="eyebrow">Admin / Chu quan</span>
        <h1>Admin co quyen them, sua, xoa mon va quan ly menu SQL theo role.</h1>
        <p>Toan bo thao tac CRUD o day deu bi khoa bang role <strong>Admin</strong> o phia server.</p>
    </div>
    <div class="intro-badges">
        <span class="status-badge">Ca hom nay: 9:00 - 22:00</span>
        <span class="status-badge muted">Cap nhat 21/03/2026</span>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="auth-alert success admin-alert">@Model.StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="auth-alert admin-alert">@Model.ErrorMessage</div>
}

<section class="metric-row">
    @foreach (var metric in topMetrics)
    {
        <article class="metric-card">
            <span>@metric.Label</span>
            <strong>@metric.Value</strong>
            <p>@metric.Note</p>
        </article>
    }
</section>

<section class="admin-grid">
    <div class="admin-main">
        <article class="panel-card admin-editor-card">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">Phan quyen menu</span>
                    <h2>@(Model.IsEditing ? "Sua mon an" : "Them mon moi")</h2>
                </div>
                <div class="inline-actions">
                    @if (Model.IsEditing)
                    {
                        <a class="btn btn-ghost btn-small" asp-action="Admin">Tao form moi</a>
                    }
                    <span class="status-badge">Role bat buoc: Admin</span>
                </div>
            </div>

            <form class="auth-form admin-editor-form" asp-action="SaveMenuItem" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Form.ItemId" type="hidden" />

                <div class="admin-editor-grid">
                    <label class="auth-field">
                        <span>Danh muc</span>
                        <select asp-for="Form.CategoryId">
                            <option value="0">Chon danh muc</option>
                            @foreach (var category in Model.Categories.OrderBy(x => x.DisplayOrder))
                            {
                                <option value="@category.CategoryId">@category.CategoryName</option>
                            }
                        </select>
                    </label>

                    <label class="auth-field">
                        <span>Ma mon</span>
                        <input asp-for="Form.ItemCode" placeholder="VD: MC007" />
                    </label>

                    <label class="auth-field">
                        <span>Ten mon</span>
                        <input asp-for="Form.Name" placeholder="Nhap ten mon" />
                    </label>

                    <label class="auth-field">
                        <span>Gia</span>
                        <input asp-for="Form.Price" type="number" min="1000" step="1000" />
                    </label>

                    <label class="auth-field">
                        <span>Thoi gian che bien (phut)</span>
                        <input asp-for="Form.PreparationTimeMinutes" type="number" min="1" max="240" />
                    </label>

                    <label class="auth-field">
                        <span>Diem pho bien</span>
                        <input asp-for="Form.PopularityScore" type="number" min="0" max="100000" />
                    </label>
                </div>

                <label class="auth-field">
                    <span>Link anh</span>
                    <input asp-for="Form.ImageUrl" placeholder="De trong neu chua gan anh" />
                </label>

                <label class="auth-field">
                    <span>Mo ta mon</span>
                    <textarea asp-for="Form.Description" rows="4" placeholder="Mo ta ngan ve thanh phan, huong vi..."></textarea>
                </label>

                <div class="admin-check-row">
                    <label class="mini-check"><input asp-for="Form.IsBestSeller" /> Best seller</label>
                    <label class="mini-check"><input asp-for="Form.IsAvailable" /> Dang ban</label>
                </div>

                <div class="auth-actions">
                    <button class="btn btn-accent" type="submit">@(Model.IsEditing ? "Luu cap nhat" : "Them mon moi")</button>
                    @if (Model.IsEditing)
                    {
                        <a class="btn btn-ghost" asp-action="Admin">Bo chon mon dang sua</a>
                    }
                </div>
            </form>
        </article>

        <article class="panel-card">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">Quan ly menu</span>
                    <h2>Danh sach mon dang co trong SQL</h2>
                </div>
                <span class="status-badge muted">Chi role Admin moi co quyen CRUD</span>
            </div>
            <div class="menu-table menu-table--media">
                <div class="menu-table__head menu-table__head--media admin-menu-head">
                    <span>Anh mon</span>
                    <span>Ten mon</span>
                    <span>Danh muc</span>
                    <span>Gia</span>
                    <span>Trang thai</span>
                    <span>Hanh dong</span>
                </div>
                @foreach (var row in Model.MenuItems)
                {
                    <div class="menu-table__row menu-table__row--media admin-menu-row">
                        @if (!string.IsNullOrWhiteSpace(row.ImageUrl))
                        {
                            <div class="menu-thumb"><img src="@row.ImageUrl" alt="@row.Name" /></div>
                        }
                        else
                        {
                            <div class="menu-thumb menu-thumb--empty"><span>Chua co anh</span></div>
                        }
                        <div>
                            <strong>@row.Name</strong>
                            <span class="table-subline">@row.ItemCode | @row.PreparationTimeMinutes phut | Score @row.PopularityScore</span>
                        </div>
                        <span>@row.CategoryName</span>
                        <span>@row.Price.ToString("N0")d</span>
                        <span>@(row.IsAvailable ? "Dang ban" : "Tam an") @(row.IsBestSeller ? "| Best seller" : string.Empty)</span>
                        <div class="table-actions">
                            <a class="btn btn-ghost btn-small" asp-action="Admin" asp-route-editItemId="@row.ItemId">Sua</a>
                            <form asp-action="DeleteMenuItem" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="itemId" value="@row.ItemId" />
                                <button class="btn btn-accent btn-small" type="submit" onclick="return confirm('Xoa mon @row.Name ?')">Xoa</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </article>

        <article class="panel-card media-manager">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">Rule phan quyen</span>
                    <h2>Admin duoc CRUD, Staff va khach khong duoc thao tac menu</h2>
                </div>
            </div>
            <div class="suggestion-stack media-guidelines">
                @foreach (var item in imageSuggestions)
                {
                    <div class="suggestion-item">
                        <strong>@item.Label</strong>
                        <span>@item.Copy</span>
                    </div>
                }
            </div>
        </article>
    </div>

    <aside class="admin-side">
        <article class="panel-card">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">QR Code theo ban</span>
                    <h3>Xuat ma dinh danh</h3>
                </div>
            </div>
            <div class="qr-grid">
                @foreach (var table in tables)
                {
                    <div class="qr-card">
                        <strong>@table</strong>
                        <div class="qr-placeholder"></div>
                        <button class="text-link" type="button">Xuat QR</button>
                    </div>
                }
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-heading">
                <div>
                    <span class="eyebrow">Ghi nho bao mat</span>
                    <h3>Server moi la noi quyet dinh quyen</h3>
                </div>
            </div>
            <div class="service-list">
                <div class="service-item">
                    <strong>GET /Home/Admin</strong>
                    <p>Chi role Admin vao duoc trang quan tri menu.</p>
                </div>
                <div class="service-item">
                    <strong>POST /Home/SaveMenuItem</strong>
                    <p>Chi Admin moi luu duoc them / sua mon, co AntiForgeryToken.</p>
                </div>
                <div class="service-item">
                    <strong>POST /Home/DeleteMenuItem</strong>
                    <p>Chi Admin moi xoa duoc mon, xoa kem option lien quan trong SQL.</p>
                </div>
            </div>
        </article>
    </aside>
</section>

