@model TableOrderWeb.Models.CustomerPageViewModel
@{
    ViewData["Title"] = "Khách tại bàn";

    var categories = Model.Categories.OrderBy(x => x.DisplayOrder).ToList();
    var sortOptions = new[]
    {
        new { Value = "popular", Label = "Phổ biến nhất" },
        new { Value = "price-asc", Label = "Giá tăng dần" },
        new { Value = "price-desc", Label = "Giá giảm dần" },
        new { Value = "name", Label = "Tên A-Z" }
    };
    var imageVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
}

<div class="customer-page" data-auto-refresh-url="@Url.Action("Customer", new { tableCode = Model.TableCode, search = Model.SearchTerm, category = Model.CategoryFilter, sort = Model.SortBy })" data-auto-refresh-seconds="20" data-live-page="customer" data-live-refresh-ms="2500">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-alert success admin-alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="auth-alert admin-alert">@Model.ErrorMessage</div>
    }

    <button class="customer-cart-fab" type="button" data-cart-open aria-controls="customer-cart-drawer" aria-label="Mở giỏ hàng">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.5 6.5h15l-1.7 8.2a2 2 0 0 1-2 1.6H9a2 2 0 0 1-2-1.6L5.4 3.8H2.5" />
            <circle cx="9.5" cy="20" r="1.3" />
            <circle cx="17.5" cy="20" r="1.3" />
        </svg>
        <span>@Model.CartItems.Sum(x => x.Quantity)</span>
    </button>

    <section class="customer-grid customer-grid--fixed-side">
        <div class="customer-main">
            <article class="panel-card menu-explorer" id="menu-list">
                <div class="menu-sticky-toolbar" data-menu-sticky-toolbar>
                    <div class="panel-heading">
                        <div>
                            <h2>Menu</h2>
                        </div>
                        <div class="inline-actions">
                            <button class="btn btn-ghost btn-small menu-toolbar-toggle" type="button" data-menu-toolbar-toggle aria-expanded="true">Thu nhỏ</button>
                            <span class="status-badge">@Model.Dishes.Count món</span>
                        </div>
                    </div>
                    <div class="menu-toolbar-body" data-menu-toolbar-body>
                        <form class="toolbar-form" method="get">
                            <input type="hidden" name="tableCode" value="@Model.TableCode" />
                            <label class="auth-field">
                                <span>Tìm tên món</span>
                                <div class="search-input-wrap">
                                    <span class="search-input-wrap__icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="11" cy="11" r="7"></circle>
                                            <path d="m20 20-3.5-3.5"></path>
                                        </svg>
                                    </span>
                                    <input type="text" name="search" value="@Model.SearchTerm" placeholder="VD: lẩu, trà đào, khoai..." />
                                </div>
                            </label>
                            <label class="auth-field">
                                <span>Danh mục</span>
                                <select name="category">
                                    <option value="all" selected="@(Model.CategoryFilter == "all" ? "selected" : null)">Tất cả</option>
                                    @foreach (var category in categories)
                                    {
                                        <option value="@category.CategoryCode" selected="@(string.Equals(Model.CategoryFilter, category.CategoryCode, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@category.CategoryName</option>
                                    }
                                </select>
                            </label>
                            <label class="auth-field">
                                <span>Sắp xếp</span>
                                <select name="sort">
                                    @foreach (var option in sortOptions)
                                    {
                                        <option value="@option.Value" selected="@(Model.SortBy == option.Value ? "selected" : null)">@option.Label</option>
                                    }
                                </select>
                            </label>
                            <div class="toolbar-actions">
                                <button class="btn btn-accent" type="submit">Áp dụng</button>
                                <a class="btn btn-ghost" asp-action="Customer" asp-route-tableCode="@Model.TableCode">Bỏ lọc</a>
                            </div>
                        </form>

                        <div class="category-row">
                            <a class="category-pill @(Model.CategoryFilter == "all" ? "active" : "")" asp-action="Customer" asp-route-tableCode="@Model.TableCode" asp-route-search="@Model.SearchTerm" asp-route-sort="@Model.SortBy">Tất cả</a>
                            @foreach (var category in categories)
                            {
                                <a class="category-pill @(string.Equals(Model.CategoryFilter, category.CategoryCode, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                                   asp-action="Customer"
                                   asp-route-tableCode="@Model.TableCode"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-sort="@Model.SortBy"
                                   asp-route-category="@category.CategoryCode">@category.CategoryName</a>
                            }
                        </div>
                    </div>
                </div>
                <div class="menu-sticky-spacer" data-menu-sticky-spacer></div>

                <div class="menu-grid">
                    @if (Model.Dishes.Count == 0)
                    {
                        <div class="panel-card empty-card">
                            <strong>Không tìm thấy món phù hợp.</strong>
                            <span>Thay đổi từ khóa tìm kiếm hoặc chọn lại danh mục.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var dish in Model.Dishes)
                        {
                            var meta = $"{dish.CategoryName} | {(dish.IsBestSeller ? "Best seller | " : string.Empty)}{dish.PreparationTimeMinutes} phút";
                            <article class="dish-card @(dish.IsAvailable ? string.Empty : "dish-card--sold-out")">
                                <div class="dish-card__image-wrap">
                                    @if (!string.IsNullOrWhiteSpace(dish.ImageUrl))
                                    {
                                        var dishImageUrl = dish.ImageUrl.StartsWith("/", StringComparison.Ordinal)
                                            ? $"{dish.ImageUrl}?v={imageVersion}"
                                            : dish.ImageUrl;
                                        <img class="dish-card__photo" src="@dishImageUrl" alt="@dish.Name" onerror="this.onerror=null;this.src='/images/menu/default-dish.svg';" />
                                    }
                                    else
                                    {
                                        <div class="dish-card__photo dish-card__photo--empty">Chưa có ảnh</div>
                                    }
                                    <span class="dish-card__badge">@dish.ItemCode</span>
                                    @if (!dish.IsAvailable)
                                    {
                                        <span class="dish-card__sold-out">Hết hàng</span>
                                    }
                                </div>
                                <div class="dish-card__body">
                                    <div class="dish-card__header">
                                        <div>
                                            <h3>@dish.Name</h3>
                                            <span>@meta</span>
                                            @if (dish.SpiceLevel > 0)
                                            {
                                                <span class="spice-level" aria-label="Mức cay @dish.SpiceLevel/5">@string.Concat(Enumerable.Repeat("🌶", dish.SpiceLevel))</span>
                                            }
                                        </div>
                                        <strong>@dish.Price.ToString("N0")đ</strong>
                                    </div>
                                    <p>@dish.Description</p>
                                    <details class="dish-details">
                                        <summary>Xem chi tiết món</summary>
                                        <div class="dish-details__content">
                                            <div>
                                                <strong>Thành phần</strong>
                                                <p>@dish.IngredientSummary</p>
                                            </div>
                                            <div>
                                                <strong>Phục vụ / khẩu phần</strong>
                                                <p>@dish.ServingSuggestion</p>
                                            </div>
                                            <div>
                                                <strong>Tùy chỉnh có sẵn</strong>
                                                <p>@dish.CustomizationSummary</p>
                                            </div>
                                        </div>
                                    </details>

                                    <form class="dish-order-form" asp-action="AddToCart" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TableCode" value="@Model.TableCode" />
                                        <input type="hidden" name="ItemId" value="@dish.ItemId" />
                                        <div class="dish-order-grid dish-order-grid--wide">
                                            <label class="auth-field">
                                                <span>Số lượng</span>
                                                <select name="Quantity">
                                                    @for (var quantity = 1; quantity <= 6; quantity++)
                                                    {
                                                        <option value="@quantity">@quantity</option>
                                                    }
                                                </select>
                                            </label>
                                            <label class="auth-field">
                                                <span>Mức đường</span>
                                                <select name="SugarLevel">
                                                    <option value="">Mặc định</option>
                                                    <option value="100%">100%</option>
                                                    <option value="70%">70%</option>
                                                    <option value="50%">50%</option>
                                                    <option value="30%">30%</option>
                                                    <option value="Không đường">Không đường</option>
                                                </select>
                                            </label>
                                            <label class="auth-field">
                                                <span>Mức đá</span>
                                                <select name="IceLevel">
                                                    <option value="">Mặc định</option>
                                                    <option value="Nhiều đá">Nhiều đá</option>
                                                    <option value="Ít đá">Ít đá</option>
                                                    <option value="Không đá">Không đá</option>
                                                </select>
                                            </label>
                                            <label class="auth-field">
                                                <span>Topping</span>
                                                <input name="ToppingChoice" placeholder="VD: tran chau, milk foam..." />
                                            </label>
                                            <label class="auth-field dish-order-grid__full">
                                                <span>Ghi chú cho bếp/bar</span>
                                                <input name="Note" placeholder="VD: không hành, ít cay, tách sốt..." />
                                            </label>
                                        </div>
                                        <div class="dish-card__actions">
                                            <button class="btn btn-accent btn-small" type="submit" disabled="@(!dish.IsAvailable)">
                                                @(dish.IsAvailable ? "Thêm vào giỏ chung" : "Hết hàng")
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </article>
                        }
                    }
                </div>
            </article>
        </div>

        <aside class="customer-side" id="customer-cart-drawer" data-cart-drawer>
            <div class="customer-side__floating">
            <article class="panel-card">
                <div class="panel-heading">
                    <div>
                        <h3>Bàn @Model.TableCode đang chọn món</h3>
                    </div>
                    <span class="status-badge">@Model.CartItems.Sum(x => x.Quantity) món</span>
                    <button class="cart-drawer-close" type="button" data-cart-close aria-label="Đóng giỏ hàng">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                @if (Model.CartItems.Count == 0)
                {
                    <div class="cart-item">
                        <div>
                            <strong>Giỏ hàng đang trống</strong>
                            <span>Hãy thêm món ở danh sách bên trái trước khi gửi order.</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="cart-stack">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="cart-item">
                                <div>
                                    <strong>@item.Name</strong>
                                    <span>@(string.IsNullOrWhiteSpace(item.Note) ? "Không có ghi chú thêm." : item.Note)</span>
                                </div>
                                <div class="cart-item__meta">
                                    <span class="cart-item__quantity">x@(item.Quantity)</span>
                                    <strong>@item.LineTotal.ToString("N0")đ</strong>
                                </div>
                                <form class="cart-remove-form" asp-action="RemoveCartItem" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="TableCode" value="@Model.TableCode" />
                                    <input type="hidden" name="ItemId" value="@item.ItemId" />
                                    <input type="hidden" name="Note" value="@item.Note" />
                                    <button class="cart-item__remove" type="submit" aria-label="Hủy @item.Name">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                    <div class="bill-box bill-stack">
                        <div><span>Tạm tính giỏ đang chọn</span><strong>@Model.CartSubtotal.ToString("N0")đ</strong></div>
                        <div><span>Phí phục vụ</span><strong>@Model.ServiceFee.ToString("N0")đ</strong></div>
                        <div class="bill-box__total"><span>Tổng gửi order</span><strong>@Model.CartTotal.ToString("N0")đ</strong></div>
                    </div>
                    <form asp-action="SubmitOrder" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TableCode" value="@Model.TableCode" />
                        <button class="btn btn-accent w-100" type="submit">Xác nhận và gửi order</button>
                    </form>
                }
            </article>

            <article class="panel-card">
                <div class="panel-heading">
                    <div>
                        <h3>Theo dõi order của bạn</h3>
                    </div>
                </div>
                @if (Model.SubmittedOrders.Count == 0)
                {
                    <div class="timeline-item">
                        <strong>Chưa có order nào được gửi.</strong>
                    </div>
                }
                else
                {
                    var progressSteps = new[] { "Đã gửi", "Đã nhận", "Đang chế biến", "Sẵn sàng", "Hoàn tất" };
                    <div class="customer-order-stack">
                        @foreach (var order in Model.SubmittedOrders)
                        {
                            <article class="customer-order-card">
                                <div class="customer-order-card__top">
                                    <div>
                                        <strong>#@order.OrderCode</strong>
                                        <span>@order.SubmittedTimeLabel | @order.ItemCount món | @order.TotalAmount.ToString("N0")đ</span>
                                    </div>
                                    <span class="status-badge">@order.StatusLabel</span>
                                </div>

                                <div class="order-progress" aria-label="Tiến trình order @order.OrderCode">
                                    @for (var stepIndex = 0; stepIndex < progressSteps.Length; stepIndex++)
                                    {
                                        var stepNumber = stepIndex + 1;
                                        <span class="order-progress__step @(order.ProgressStep >= stepNumber ? "is-done" : "")">
                                            <i>@stepNumber</i>
                                            <small>@progressSteps[stepIndex]</small>
                                        </span>
                                    }
                                </div>

                                <div class="customer-order-items">
                                    @foreach (var item in order.Items)
                                    {
                                        <div class="customer-order-item">
                                            <div>
                                                <strong>@item.Name</strong>
                                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                                {
                                                    <span>@item.Note</span>
                                                }
                                            </div>
                                            <span>@item.LineTotal.ToString("N0")đ</span>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                    <div class="bill-box bill-stack">
                        <div><span>Tạm tính đơn đã gửi</span><strong>@Model.SubmittedSubtotal.ToString("N0")đ</strong></div>
                        <div><span>Phí phục vụ</span><strong>@Model.SubmittedServiceFee.ToString("N0")đ</strong></div>
                        <div class="bill-box__total"><span>Tổng thanh toán</span><strong>@Model.SubmittedTotal.ToString("N0")đ</strong></div>
                    </div>
                }
            </article>

            @if (Model.CanSubmitReview)
            {
                <article class="panel-card customer-review-card">
                    <div class="panel-heading">
                        <div>
                            <h3>Đánh giá món đã phục vụ</h3>
                        </div>
                        <span class="status-badge">5 sao</span>
                    </div>

                    <form class="customer-review-form" asp-action="SubmitReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TableCode" value="@Model.TableCode" />
                        <input type="hidden" name="ServiceRating" value="0" />
                        <div class="star-rating" aria-label="Chọn số sao đánh giá">
                            @for (var rating = 5; rating >= 1; rating--)
                            {
                                <input id="food-rating-@rating" type="radio" name="FoodRating" value="@rating" checked="@(rating == 5 ? "checked" : null)" />
                                <label for="food-rating-@rating" title="@rating sao">★</label>
                            }
                        </div>
                        <textarea name="Comment" maxlength="300" rows="3" placeholder="Nhận xét của bạn về món ăn, phục vụ..."></textarea>
                        <button class="btn btn-accent w-100" type="submit">Gửi đánh giá</button>
                    </form>

                    @if (Model.RecentReviews.Count > 0)
                    {
                        <div class="customer-review-list">
                            @foreach (var review in Model.RecentReviews.Take(2))
                            {
                                <div class="customer-review-item">
                                    <strong>@review.FoodRating/5 sao</strong>
                                    <span>@review.CreatedAtLabel</span>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p>@review.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </article>
            }

            <article class="panel-card customer-chat-card"
                     data-chat-panel="customer"
                     data-chat-table="@Model.TableCode"
                     data-chat-url="@Url.Action("CustomerChatMessages", new { tableCode = Model.TableCode })">
                <div class="panel-heading">
                    <div>
                        <h3>Bàn @Model.TableCode cần hỗ trợ</h3>
                    </div>
                    <span class="status-badge" data-chat-count>@Model.ChatMessages.Count tin</span>
                </div>

                <div class="customer-chat-thread" data-chat-thread>
                    @if (Model.ChatMessages.Count == 0)
                    {
                        <div class="chat-empty">
                            <strong>Chưa có tin nhắn.</strong>
                            <span>Nhắn món thiếu, xin thêm chén, gọi nhân viên hoặc hỏi thanh toán.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var message in Model.ChatMessages)
                        {
                            var side = string.Equals(message.SenderRole, "Customer", StringComparison.OrdinalIgnoreCase) ? "mine" : "theirs";
                            <div class="chat-bubble chat-bubble--@message.Direction chat-message chat-message--@side" data-message-id="@message.MessageId">
                                @if (side == "theirs")
                                {
                                    <strong class="chat-message__name">@message.SenderName</strong>
                                }
                                <p>@message.Message</p>
                                <small class="chat-message__time">@message.TimeLabel</small>
                            </div>
                        }
                    }
                </div>

                <form class="customer-chat-form" asp-action="SendCustomerMessage" method="post" data-chat-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TableCode" value="@Model.TableCode" />
                    <input name="Message" maxlength="300" autocomplete="off" placeholder="Nhắn cho nhân viên..." />
                    <button class="btn btn-accent btn-small" type="submit">Gửi</button>
                </form>
            </article>
            </div>
        </aside>
        <button class="cart-drawer-backdrop" type="button" data-cart-close aria-label="Đóng giỏ hàng"></button>
    </section>
</div>
