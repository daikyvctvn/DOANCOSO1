@model TableOrderWeb.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-wrap">
    <article class="auth-card">
        <span class="eyebrow">Tài khoản hệ thống</span>
        <h1>Đăng nhập</h1>
        <p>Đăng nhập để vào màn hình Nhân viên hoặc Quản trị.</p>

        @if (TempData["AuthMessage"] is string message)
        {
            <div class="auth-alert success">@message</div>
        }

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label class="auth-field">
                <span>Tên đăng nhập</span>
                <input asp-for="UserName" placeholder="Ví dụ: lan.staff" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </label>

            <label class="auth-field">
                <span>Mật khẩu</span>
                <input asp-for="Password" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </label>

            <div class="auth-actions">
                <button class="btn btn-accent" type="submit">Đăng nhập</button>
                <a class="btn btn-ghost" asp-controller="Account" asp-action="Register">Đăng ký</a>
            </div>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
