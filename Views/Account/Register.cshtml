@model TableOrderWeb.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-wrap">
    <article class="auth-card">
        <span class="eyebrow">Tạo tài khoản</span>
        <h1>Đăng ký</h1>
        <p>Tạo tài khoản mới để đăng nhập vào màn hình Nhân viên hoặc Quản trị.</p>
        <p>Lưu ý: hệ thống chỉ cho phép duy nhất 1 tài khoản Quản trị.</p>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label class="auth-field">
                <span>Tên hiển thị</span>
                <input asp-for="DisplayName" placeholder="Ví dụ: Nguyễn Lan" />
                <span asp-validation-for="DisplayName" class="text-danger"></span>
            </label>

            <label class="auth-field">
                <span>Tên đăng nhập</span>
                <input asp-for="UserName" placeholder="Ví dụ: lan.staff" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </label>

            <label class="auth-field">
                <span>Vai trò</span>
                <select asp-for="Role">
                    <option value="Staff">Nhân viên</option>
                    <option value="Admin">Quản trị</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </label>

            <label class="auth-field">
                <span>Mật khẩu</span>
                <input asp-for="Password" placeholder="Tối thiểu 6 ký tự" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </label>

            <label class="auth-field">
                <span>Nhập lại mật khẩu</span>
                <input asp-for="ConfirmPassword" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </label>

            <div class="auth-actions">
                <button class="btn btn-accent" type="submit">Đăng ký</button>
                <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Đã có tài khoản</a>
            </div>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
